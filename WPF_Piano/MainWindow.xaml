<Window x:Class="WPF_Piano.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WPF_Piano"
        Title="Piano Studio Pro" Height="950" Width="1600"
        Background="#121212">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#181818" CornerRadius="12" Margin="5">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="LIBRARY" Foreground="#555" FontWeight="Bold" Margin="5,0,0,10"/>

                <Button Grid.Row="1" Click="Button_Click" Height="40" Background="#252525" Foreground="White" BorderThickness="0" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+" FontWeight="Bold" FontSize="18" Margin="0,-2,10,0"/>
                        <TextBlock Text="Import MIDI File" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <ListView x:Name="SongListView" Grid.Row="2" Background="Transparent" BorderThickness="0" Foreground="#AAA">
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="5">
            <Viewbox Stretch="Fill" SnapsToDevicePixels="True">

                <Border BorderBrush="White" BorderThickness="5" CornerRadius="0,0,12,12" Width="2520" Height="1400" >
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="80"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"  ClipToBounds="True" BorderBrush="#222" BorderThickness="1">
                            <ScrollViewer Name="NoteFrame" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
                                <local:NoteControl x:Name="NoteControl" Width="2520" />
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="1" Background="#111" BorderBrush="#222" BorderThickness="1,0,1,1">
                            <Viewbox Stretch="Fill">
                                <StackPanel x:Name="PianoButtonOctave" Orientation="Horizontal"/>
                            </Viewbox>
                        </Border>

                        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="0,0,9,9" BorderBrush="#222" >
                            <Grid Margin="20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button RenderOptions.EdgeMode="Aliased" SnapsToDevicePixels="True" Click="Play" Width="60" Height="60" Background="#00FFCC" BorderThickness="2" BorderBrush="#00FFCC">
                                        <Image Source="/Resources/play-button.png"  Stretch="Fill"></Image>
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="30"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button Click="Pause" Width="60" Height="60" Background="#333" BorderThickness="0" Margin="10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="4" Height="16" Fill="White" Margin="2"/>
                                            <Rectangle Width="4" Height="16" Fill="White" Margin="2"/>
                                        </StackPanel>
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="30"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>

                                <Slider Grid.Column="1" x:Name="TimelineSlider" 
                            VerticalAlignment="Center" Margin="30,0"
                            Minimum="0" Maximum="100" />

                                <TextBlock Grid.Column="2" x:Name="TimeDisplay" 
                               Text="00:00 / 00:00" VerticalAlignment="Center" 
                               Foreground="#888" FontSize="20" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Viewbox>
        </Grid>
    </Grid>
</Window>