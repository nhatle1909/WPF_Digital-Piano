<Window x:Class="WPF_Piano.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Piano"
        mc:Ignorable="d"
        Title="Settings" Height="700" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#0B0B0B" 
        WindowStyle="None" ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="13" FontWeight="Medium" Margin="0,0,0,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Padding="0,12,32,12" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00FFCC"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Width" Value="200"/>
          
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="PianoRowSelectionStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#1A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#161616"/>
                    <Setter Property="BorderBrush" Value="#00FFCC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15,15,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Preferences" FontSize="22" FontWeight="Light" Foreground="#FFFFFF"/>
            <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#fff" FontSize="16" Click="Close_Click" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <TabControl Grid.Row="1" Margin="0,10,0,0">

            <TabItem Header="Keyboard">
                <StackPanel Margin="0,25,0,0">
                    <TextBlock Text="LAYOUT &amp; INPUT" Foreground="#555555" FontSize="11" FontWeight="Bold" Margin="0,0,0,15" />

                    <Grid Margin="15,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Keyboard Input Map" VerticalAlignment="Center" Foreground="#A0A0A0"/>
                        <ComboBox Grid.Column="1">
                           
                        </ComboBox>
                    </Grid>
                    <Grid Margin="15,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="100"/>
                            
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Octave Range" VerticalAlignment="Center" Foreground="#A0A0A0"/>
                        <TextBlock Grid.Column="1" Text="From" VerticalAlignment="Center" Foreground="#A0A0A0"/>
                        <ComboBox Grid.Column="2" Margin="0,0,10,0" SelectedIndex="0">
                            <ComboBoxItem Content="C1"/>
                            <ComboBoxItem Content="C2"/>
                            <ComboBoxItem Content="C3"/>
                        </ComboBox>
                        <TextBlock Grid.Column="3" Text="To" VerticalAlignment="Center" Foreground="#A0A0A0"/>
                        <ComboBox Grid.Column="4" Margin="0,0,10,0" SelectedIndex="2">
                            <ComboBoxItem Content="C6"/>
                            <ComboBoxItem Content="C7"/>
                            <ComboBoxItem Content="C8"/>
                        </ComboBox>
                    </Grid>
                    <TextBlock Text="Keyboard mapping" Foreground="#555555" FontSize="11" FontWeight="Bold" Margin="0,0,0,15" />
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" Height="322" Margin="15,0,15,0">

                        <ListBox x:Name="MappingList"
                                 ItemsSource="{Binding PianoKeys}" 
                                 SelectedItem="{Binding SelectedPianoKey, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource PianoRowSelectionStyle}"
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 KeyDown="MappingList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="580">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="NOTE" Foreground="#444444" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Note}" Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" Text="ASSIGNED" Foreground="#444444" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Key}" Foreground="#00FFCC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>

        </TabControl>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Border BorderBrush="#1A1A1A" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
            <Button Click="Save_Click"
                    Content="Done" Width="90" Height="34" HorizontalAlignment="Right" Background="#FFFFFF"
                    Foreground="#0A0A0A" FontWeight="Medium" FontSize="13" BorderThickness="0" Margin="0,15,0,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
